# Operator-only credentials — copy to .env locally; never commit .env
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-operator-key-from-secret-manager

# Anon key for user-scoped (RLS-enforced) account-data access — safe to be
# non-secret (same key shipped in dxsh.blxckbook.jexxx.us / dxsh.nxt.jexxx.us
# browser bundles as VITE_SUPABASE_ANON_KEY). Used by createUserSupabaseClient()
# in src/lib/user-supabase.ts, paired with the signed-in user's own Clerk JWT
# from ~/.jexxxus/credentials.json — NEVER the service-role key above.
SUPABASE_ANON_KEY=your-project-anon-key

# End-user vault reads (account_query, /account export, export_vault) — API-first with
# direct Supabase fallback when api.jexxx.us is unreachable. Server hosts must set
# JEXXXUS_ACCOUNT_API=off to prevent HTTP loopback.
# JEXXXUS_API_URL=https://api.jexxx.us
# JEXXXUS_ACCOUNT_API=off

# Optional — BLXCKCHAT /divinities persona vault (auto-detected when jexxx.us-obsidian
# sits beside jexxx.us-cli in the JEXXXUS monorepo; set explicitly otherwise)
# JEXXXUS_OBSIDIAN_PERSONAS_PATH=../jexxx.us-obsidian/Divinities