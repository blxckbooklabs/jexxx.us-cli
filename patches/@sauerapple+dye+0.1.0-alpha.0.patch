+/**
+ * Serialize a Screen buffer (packed charId/styleId cells) into a styled ANSI
+ * string, using StylePool's cached transition() escapes for minimal codes.
+ *
+ * Needed because Output.get() builds two PARALLEL representations of the
+ * same frame in the same pass -- a plain 2D character grid (which the
+ * returned `output` string is generated from) and this packed Screen buffer
+ * (which selection tracking/overlay operates on). Mutating the Screen buffer
+ * after Output.get() has already returned has zero effect on the `output`
+ * string, since that string was serialized from the OTHER representation
+ * before the mutation ever happens. applySelectionOverlay() correctly
+ * colors Screen cells pink, but without this function to re-derive `output`
+ * from the mutated Screen afterward, none of that ever reaches the
+ * terminal -- selection tracking/copy still works (it reads Screen cell
+ * content directly), but the visual highlight silently never renders.
+ */
+import { getCellCharId, getCellWord1, unpackStyleId, unpackWidth, CellWidth, } from './screen.js';
+
+export function screenToStyledString(screen) {
+    const lines = [];
+    for (let y = 0; y < screen.height; y++) {
+        let line = '';
+        let currentStyleId = 0;
+        for (let x = 0; x < screen.width; x++) {
+            const w1 = getCellWord1(screen, x, y);
+            const width = unpackWidth(w1);
+            if (width === CellWidth.SpacerTail) {
+                continue;
+            }
+            const styleId = unpackStyleId(w1);
+            if (styleId !== currentStyleId) {
+                line += screen.stylePool.transition(currentStyleId, styleId);
+                currentStyleId = styleId;
+            }
+            const charId = getCellCharId(screen, x, y);
+            line += screen.charPool.resolve(charId);
+        }
+        if (currentStyleId !== 0) {
+            line += screen.stylePool.transition(currentStyleId, 0);
+        }
+        lines.push(line.trimEnd());
+    }
+    return lines.join('\n');
+}
