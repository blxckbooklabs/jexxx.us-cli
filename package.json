{
  "name": "jexxx.us-cli",
  "version": "1.0.0",
  "description": "The native CLI agent tool for JEXXXUS",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./agent-loop": "./dist/lib/blxckchat/agent-loop.js",
    "./tools/registry": "./dist/lib/blxckchat/tools/registry.js",
    "./account-data/session": "./dist/lib/account-data/session.js",
    "./account-routing": "./dist/lib/blxckchat/account-routing.js",
    "./kingdom-routing": "./dist/lib/blxckchat/kingdom-routing.js",
    "./account-prefetch": "./dist/lib/blxckchat/account-prefetch.js",
    "./garden-prefetch": "./dist/lib/blxckchat/garden-prefetch.js",
    "./operator-identity": "./dist/lib/operator-identity.js",
    "./super-admin": "./dist/lib/super-admin.js",
    "./user-supabase": "./dist/lib/user-supabase.js"
  },
  "bin": {
    "jexxxus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),f='dist/index.js';const s=fs.readFileSync(f,'utf8');if(!s.startsWith('#!/usr/bin/env node')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+s)};fs.chmodSync(f,0o755)\"",
    "start": "ts-node src/index.ts",
    "test": "npm run build && node --test dist/__tests__/*.test.js",
    "smoke:rls": "npm run build && node dist/scripts/rls-smoke-test.js",
    "postinstall": "patch-package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blxckbooklabs/jexxx.us-cli.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/blxckbooklabs/jexxx.us-cli/issues"
  },
  "homepage": "https://github.com/blxckbooklabs/jexxx.us-cli#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@sauerapple/dye": "^0.1.0-alpha.0",
    "@supabase/supabase-js": "^2.107.0",
    "blessed": "^0.1.81",
    "chalk": "^4.1.2",
    "commander": "^15.0.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "marked": "^15.0.12",
    "openai": "^4.77.0",
    "react": "^19.2.7",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-reconciler": "^0.33.0",
    "patch-package": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
